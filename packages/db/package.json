{
	"name": "@modflix/db",
	"version": "0.0.0",
	"private": true,
	"main": "src/index.ts",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./orm": "./src/orm.ts",
		"./schema": "./src/schema.ts"
	},
	"files": [
		"src/**/*"
	],
	"scripts": {
		"db:check": "drizzle-kit check --config=src/drizzle.config.ts",
		"db:dz:gen": "drizzle-kit generate --config=src/drizzle.config.ts",
		"db:migrate": "tsx ./scripts/migrate.ts",
		"db:gen-schema": "tsx ./scripts/gen-schema.ts",
		"db:generate": "run-s db:gen-schema db:dz:gen"
	},
	"dependencies": {
		"dotenv": "^17.2.1",
		"drizzle-orm": "^0.45.2",
		"pg": "^8.13.1",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"@modflix/biome-config": "workspace:*",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.31.10",
		"npm-run-all2": "^8.0.4",
		"tsx": "^4.19.2",
		"typescript": "^5.2.2"
	}
}
