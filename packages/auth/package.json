{
	"name": "@modflix/auth",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"import": "./src/client.ts",
			"default": "./src/client.ts"
		},
		"./helper": {
			"import": "./src/helper.ts",
			"default": "./src/helper.ts"
		},
		"./roles": {
			"import": "./src/roles.ts",
			"default": "./src/roles.ts"
		},
		"./better-auth": {
			"import": "./src/bta.ts",
			"default": "./src/bta.ts"
		},
		"./better-auth-client": {
			"import": "./src/btac.ts",
			"default": "./src/btac.ts"
		},
		"./better-auth-react": {
			"import": "./src/btareact.ts",
			"default": "./src/btareact.ts"
		}
	},
	"types": "src/index.ts",
	"files": [
		"src/**/*"
	],
	"scripts": {
		"auth:seed": "tsx src/seed.ts"
	},
	"devDependencies": {
		"@modflix/biome-config": "workspace:*",
		"tsx": "^4.20.5"
	},
	"dependencies": {
		"@modflix/db": "workspace:*",
		"dotenv": "^17.2.1",
		"better-auth": "^1.3.7",
		"zod": "^4.0.17"
	}
}
