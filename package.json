{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:check": "bun run --filter @modflix/db db:check",
    "db:generate": "bun run --filter @modflix/db db:generate",
    "db:migrate": "bun run --filter @modflix/db db:migrate",
    "auth:seed": "bun run --filter @modflix/auth auth:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@modflix/biome-config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "zod": "^4.3.6"
  }
}
